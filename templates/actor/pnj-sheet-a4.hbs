<form class="ims-sheet ims-extra ys-a4-sheet {{themeClass}}" autocomplete="off">
  <header class="ims-extra-header compact">
    <img src="{{actor.img}}" data-edit="img" alt="">
    <div class="ims-extra-id">
      <img class="ys-a4-extra-logo" src="{{logoPath}}" alt="IMSERSO to the Limit">
      <input class="ims-title-input" name="name" value="{{actor.name}}">
      <div class="ims-extra-meta">
        <input name="system.rol" value="{{system.rol}}" placeholder="Rol">
        <input name="system.bando" value="{{system.bando}}" placeholder="Bando">
      </div>
    </div>
    <div class="ims-extra-actions">
      <button type="button" title="Iniciativa" data-roll-initiative><i class="fas fa-forward"></i></button>
      <button type="button" title="Ataque" data-help-type="rule" data-help-key="ataque" data-roll-attack><i class="fas fa-dice-six"></i></button>
      <button type="button" title="Reservar" data-roll-reserve><i class="fas fa-hourglass-half"></i></button>
      <button type="button" title="Daño" data-damage><i class="fas fa-kit-medical"></i></button>
      <button type="button" title="Curar" data-heal><i class="fas fa-hand-holding-medical"></i></button>
    </div>
  </header>

  <section class="ims-body single ims-extra-body">
    <section class="ims-extra-top">
      <div class="ims-extra-card ims-extra-attrs">
        <h3>Atributos</h3>
        <div class="ims-extra-attr-grid">
          {{#each atributos}}
          <label data-help-type="attribute" data-help-key="{{key}}"><span>{{short}}</span><input type="number" name="system.atributos.{{key}}" value="{{value}}" step="1"></label>
          {{/each}}
        </div>
      </div>

      <div class="ims-extra-card ims-extra-values">
        <h3>Valores</h3>
        <div class="ims-extra-value-grid">
          <label data-help-type="rule" data-help-key="aplomo"><span>{{ysFixed "aplomo"}}</span><input type="number" name="system.aplomo.valor" value="{{system.aplomo.valor}}"></label>
          <label data-help-type="rule" data-help-key="agilidad"><span>{{ysFixed "agilidad"}}</span><input type="number" name="system.agilidad.valor" value="{{system.agilidad.valor}}"></label>
          <label data-help-type="rule" data-help-key="perspicacia"><span>{{ysFixed "perspicacia"}}</span><input type="number" name="system.perspicacia.valor" value="{{system.perspicacia.valor}}"></label>
          <label data-help-type="rule" data-help-key="resistenciaFisica"><span>{{imsTerm "rf"}}</span><input type="number" name="system.resistenciaFisica.valor" value="{{system.resistenciaFisica.valor}}"></label>
          <label><span>{{imsTerm "salud"}}</span><input type="number" name="system.salud.valor" value="{{system.salud.valor}}"></label>
          <label><span>Max</span><input type="number" name="system.salud.max" value="{{system.salud.max}}"></label>
        </div>
      </div>

      <div class="ims-extra-card ims-extra-attack">
        <h3>Ataque</h3>
        <div class="ims-effective-attack {{#if effectiveAttack.equipped}}equipped{{/if}}">
          <b>{{effectiveAttack.name}}</b>
          <span>{{effectiveAttack.source}}</span>
          <small>{{effectiveAttack.skillLabel}} · Daño {{effectiveAttack.damage}} + {{effectiveAttack.attrLabel}} · Ini +{{effectiveAttack.initiative}}</small>
        </div>
        <label class="check"><input type="checkbox" name="system.combate.sorprendido" {{imsChecked system.combate.sorprendido}}> Pillado por sorpresa</label>
      </div>
    </section>

    <section class="ims-number-section ims-health ims-extra-health compact" data-help-type="rule" data-help-key="salud">
      <h2>{{imsTerm "salud"}}</h2>
      <div class="ims-health-track" style="{{healthGridStyle}}">
        {{#each healthTrack}}
        <button type="button" data-help-type="rule" data-help-key="salud" data-health="{{value}}" class="zone-{{zone}} {{#if active}}active{{/if}} {{#if threshold}}threshold{{/if}}">
          <span></span><b>{{value}}</b>
        </button>
        {{/each}}
      </div>
    </section>

    <section class="ims-extra-main">
      <section class="ims-extra-card ims-extra-skills">
        <h3>Habilidades</h3>
        <div class="ims-skill-table compact">
          {{#each habilidades}}
          <div class="ims-skill-row">
            <button type="button" data-help-type="skill" data-help-key="{{key}}" data-roll-skill="{{key}}">{{label}} ({{attrLabel}})</button>
            <div class="ims-dots ys-dice">
              {{#each dots}}
              <button type="button" class="ims-dot ims-die {{#if active}}active{{/if}}" data-skill-dot="{{../key}}" data-value="{{value}}" title="{{value}}D"></button>
              {{/each}}
            </div>
          </div>
          {{/each}}
        </div>
      </section>

      <section class="ims-inventory ims-extra-inventory compact" data-help-type="section" data-help-key="pertenencias">
        <header>
          <h2>{{imsTerm "equipo"}}</h2>
          <div>
            {{#each itemCreateTypes}}
            <button type="button" title="Crear {{label}}" data-item-create="{{type}}"><i class="fas {{icon}}"></i></button>
            {{/each}}
          </div>
        </header>
        {{#each itemSections}}
        <h3>{{label}}</h3>
        <ol>
          {{#each items}}
          <li class="item {{#if system.equipado}}equipped{{/if}}" data-item-id="{{id}}">
            <img src="{{imsItemIcon type}}" alt="">
            <span>{{name}}</span>
            <button type="button" data-item-equip title="Equipar"><i class="fas fa-shirt"></i></button>
            <button type="button" data-item-use title="Usar"><i class="fas fa-dice-six"></i></button>
            <button type="button" data-item-edit title="Editar"><i class="fas fa-pen"></i></button>
            <button type="button" data-item-delete title="Borrar"><i class="fas fa-trash"></i></button>
          </li>
          {{/each}}
        </ol>
        {{/each}}
      </section>
    </section>

    <section class="ims-notes two compact">
      <label>Descripción<textarea name="system.descripcion">{{system.descripcion}}</textarea></label>
      <label>Notas<textarea name="system.notas">{{system.notas}}</textarea></label>
    </section>
  </section>
</form>
