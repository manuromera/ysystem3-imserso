<form class="ims-sheet ys-screen-sheet ys-pnj {{themeClass}}" autocomplete="off">
  <header class="ys-screen-header compact">
    <img class="ys-portrait" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" alt="Retrato">
    <section class="ys-identity">
      <div class="ys-brand">
        <img src="modules/ysystem3-imserso/assets/branding/module-icon.png" alt="IMSERSO to the Limit">
        <strong>IMSERSO</strong>
        <span>{{imsUI "moduleTitle"}} · PNJ</span>
      </div>
      <div class="ys-title-line">
        <input class="ys-title-input" name="name" value="{{actor.name}}" placeholder="Nombre del PNJ">
        <label>Rol<input name="system.rol" value="{{system.rol}}"></label>
        <label>Bando<input name="system.bando" value="{{system.bando}}"></label>
      </div>
    </section>
  </header>

  <nav class="ims-tabs ys-tabs" data-group="primary">
    <a class="item" data-tab="ficha"><i class="fas fa-id-card"></i><span>Resumen</span></a>
    <a class="item" data-tab="combate"><i class="fas fa-shield-halved"></i><span>Combate</span></a>
    <a class="item" data-tab="equipo"><i class="fas fa-suitcase"></i><span>{{imsTerm "equipo"}}</span></a>
    <a class="item" data-tab="notas"><i class="fas fa-book-open"></i><span>Notas</span></a>
    <div class="ys-tab-actions">
      <button type="button" title="Iniciativa" data-roll-initiative><i class="fas fa-forward"></i><span>Ini</span></button>
      <button type="button" title="Ataque" data-help-type="rule" data-help-key="ataque" data-roll-attack><i class="fas fa-dice-six"></i><span>Atq</span></button>
      <button type="button" title="Daño" data-damage><i class="fas fa-kit-medical"></i><span>Daño</span></button>
      <button type="button" title="Curar" data-heal><i class="fas fa-hand-holding-medical"></i><span>Curar</span></button>
    </div>
  </nav>

  <aside class="ims-help-box ims-sheet-help">
    <strong>{{imsHelpTitle "salud"}}</strong>
    <p>{{imsHelpText "salud"}}</p>
    <strong>{{imsHelpTitle "rf"}}</strong>
    <p>{{imsHelpText "rf"}}</p>
  </aside>

  <section class="ims-body ys-body">
    <div class="tab ims-tab-panel ys-panel" data-group="primary" data-tab="ficha">
      <main class="ys-panel-grid">
        <section class="ys-card ys-attr-card">
          <header><h2>Atributos</h2></header>
          <div class="ys-attr-grid">
            {{#each atributos}}
            <label data-help-type="attribute" data-help-key="{{key}}">
              <span>{{short}}</span>
              <input type="number" name="system.atributos.{{key}}" value="{{value}}" step="1">
            </label>
            {{/each}}
          </div>
        </section>

        <section class="ys-card ys-derived-card">
          <header><h2>Valores</h2></header>
          <div class="ys-value-grid">
            <label data-help-type="rule" data-help-key="aplomo"><span>{{ysFixed "aplomo"}}</span><input type="number" name="system.aplomo.valor" value="{{system.aplomo.valor}}"></label>
            <label data-help-type="rule" data-help-key="agilidad"><span>{{ysFixed "agilidad"}}</span><input type="number" name="system.agilidad.valor" value="{{system.agilidad.valor}}"></label>
            <label data-help-type="rule" data-help-key="perspicacia"><span>{{ysFixed "perspicacia"}}</span><input type="number" name="system.perspicacia.valor" value="{{system.perspicacia.valor}}"></label>
            <label data-help-type="rule" data-help-key="resistenciaFisica"><span>{{imsTerm "rf"}}</span><input type="number" name="system.resistenciaFisica.valor" value="{{system.resistenciaFisica.valor}}"></label>
            <label><span>{{imsTerm "salud"}}</span><input type="number" name="system.salud.valor" value="{{system.salud.valor}}"></label>
            <label><span>Max</span><input type="number" name="system.salud.max" value="{{system.salud.max}}"></label>
            <label><span>{{imsTerm "armadura"}}</span><input type="number" value="{{system.proteccion.dano}}" disabled></label>
            <label><span>{{imsTerm "escudo"}}</span><input type="number" value="{{system.proteccion.agilidad}}" disabled></label>
          </div>
          <div class="ys-form-grid two">
            <label class="check"><input type="checkbox" name="system.aplomo.manual" {{imsChecked system.aplomo.manual}}> Fijar {{ysFixed "aplomo"}}</label>
            <label class="check"><input type="checkbox" name="system.agilidad.manual" {{imsChecked system.agilidad.manual}}> Fijar {{ysFixed "agilidad"}}</label>
            <label class="check"><input type="checkbox" name="system.perspicacia.manual" {{imsChecked system.perspicacia.manual}}> Fijar {{ysFixed "perspicacia"}}</label>
            <label class="check"><input type="checkbox" name="system.resistenciaFisica.manual" {{imsChecked system.resistenciaFisica.manual}}> Fijar {{imsTerm "rf"}}</label>
          </div>
        </section>

        <section class="ys-card ys-wide-card ys-health-card" data-help-type="rule" data-help-key="salud">
          <header>
            <h2>{{imsTerm "salud"}}</h2>
          </header>
          <div class="ims-health-track ys-health-track" style="{{healthGridStyle}}">
            {{#each healthTrack}}
            <button type="button" data-help-type="rule" data-help-key="salud" data-health="{{value}}" class="zone-{{zone}} {{#if active}}active{{/if}} {{#if threshold}}threshold{{/if}}">
              <span></span><b>{{value}}</b>
            </button>
            {{/each}}
          </div>
        </section>

        <section class="ys-card ys-wide-card ys-summary-skills-card">
          <header><h2>Habilidades</h2></header>
          <div class="ys-skill-grid summary">
            {{#each habilidades}}
            <div class="ys-skill-row">
              <button type="button" data-help-type="skill" data-help-key="{{key}}" data-roll-skill="{{key}}">
                <span>{{label}}</span>
                <small>{{attrLabel}}</small>
              </button>
              <div class="ims-dots ys-dice ys-dots" aria-label="{{dados}} dados">
                {{#each dots}}
                <button type="button" class="ims-dot ims-die {{#if active}}active{{/if}}" data-skill-dot="{{../key}}" data-value="{{value}}" title="{{value}}D"></button>
                {{/each}}
              </div>
            </div>
            {{/each}}
          </div>
        </section>
      </main>
    </div>

    <div class="tab ims-tab-panel ys-panel" data-group="primary" data-tab="combate">
      <main class="ys-panel-grid">
        <section class="ys-card ys-wide-card ys-combat-actions-card">
          <header><h2>Ataque activo</h2></header>
          <div class="ys-combat-action-layout">
            <div class="ys-effective-attack {{#if effectiveAttack.equipped}}equipped{{/if}}">
              <b>{{effectiveAttack.name}}</b>
              <span>{{effectiveAttack.source}}</span>
              <small>{{effectiveAttack.skillLabel}} · Daño {{effectiveAttack.damage}} + {{effectiveAttack.attrLabel}} · Ini +{{effectiveAttack.initiative}}</small>
            </div>
            <div class="ys-combat-action-tools">
              <div class="ys-action-grid">
                <button type="button" data-roll-initiative><i class="fas fa-forward"></i> Iniciativa</button>
                <button type="button" data-help-type="rule" data-help-key="ataque" data-roll-attack><i class="fas fa-dice-six"></i> Ataque</button>
                <button type="button" data-roll-reserve><i class="fas fa-hourglass-half"></i> Reservar</button>
              </div>
              <label class="check"><input type="checkbox" name="system.combate.sorprendido" {{imsChecked system.combate.sorprendido}}> Pillado por sorpresa</label>
            </div>
          </div>
        </section>
      </main>
    </div>

    <div class="tab ims-tab-panel ys-panel" data-group="primary" data-tab="equipo">
      <section class="ys-card ys-full-card ys-inventory-card" data-help-type="section" data-help-key="pertenencias">
        <header>
          <h2>{{imsTerm "equipo"}}</h2>
          <div class="ys-status-actions">
            {{#each itemCreateTypes}}
            <button type="button" data-item-create="{{type}}"><i class="fas {{icon}}"></i> {{label}}</button>
            {{/each}}
          </div>
        </header>
        {{#if equipmentNotes.length}}
        <p class="ims-equipped-note">Equipado: {{#each equipmentNotes}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>
        {{/if}}
        {{#each itemSections}}
        <h3>{{label}}</h3>
        <ol class="ys-item-list">
          {{#each items}}
          <li class="item {{#if system.equipado}}equipped{{/if}}" data-item-id="{{id}}">
            <img src="{{imsItemIcon type}}" alt="">
            <span>{{name}}</span>
            <button type="button" data-item-equip title="Equipar"><i class="fas fa-shirt"></i></button>
            <button type="button" data-item-use title="Usar"><i class="fas fa-dice-six"></i></button>
            <button type="button" data-item-chat title="Enviar al chat"><i class="fas fa-comment"></i></button>
            <button type="button" data-item-edit title="Editar"><i class="fas fa-pen"></i></button>
            <button type="button" data-item-delete title="Borrar"><i class="fas fa-trash"></i></button>
          </li>
          {{/each}}
        </ol>
        {{/each}}
      </section>
    </div>

    <div class="tab ims-tab-panel ys-panel" data-group="primary" data-tab="notas">
      <section class="ys-card ys-full-card">
        <header><h2>Notas</h2></header>
        <div class="ys-form-grid">
          <label>Descripción<textarea name="system.descripcion">{{system.descripcion}}</textarea></label>
          <label>Notas<textarea name="system.notas">{{system.notas}}</textarea></label>
        </div>
      </section>
    </div>
  </section>
</form>
