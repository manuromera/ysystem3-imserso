<form class="ims-sheet ims-item {{themeClass}}" autocomplete="off">
  <header class="ims-item-header">
    <img src="{{itemIcon}}" data-edit="img" alt="{{itemTypeLabel}}">
    <div class="ims-item-head-main">
      <div class="ims-item-title-block">
        <span>{{itemTypeLabel}}</span>
        <input class="ims-title-input" name="name" value="{{item.name}}">
      </div>
      <div class="ims-item-actions">
        <button type="button" data-item-use><i class="fas fa-dice-six"></i> Usar</button>
        <button type="button" data-item-chat><i class="fas fa-comment"></i> Chat</button>
      </div>
    </div>
  </header>

  <aside class="ims-help-box ims-item-help">
    <strong>{{itemTypeLabel}}</strong>
    <p>La ficha mantiene el tipo interno de YSYSTEM3 y solo cambia su presentacion IMSERSO, icono y lenguaje visible.</p>
  </aside>

  {{#if (eq item.type "arma")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields arma-fields">
      <label>Tipo
        <select name="system.tipo">
          {{#each config.ataqueTipos}}<option value="{{@key}}" {{imsSelected @key ../system.tipo}}>{{label}}</option>{{/each}}
        </select>
      </label>
      <label>Habilidad
        <select name="system.habilidad">
          {{#each config.habilidades}}<option value="{{@key}}" {{imsSelected @key ../system.habilidad}}>{{label}}</option>{{/each}}
        </select>
      </label>
      <label>Atributo al daño
        <select name="system.atributoDano">
          {{#each config.atributos}}<option value="{{@key}}" {{imsSelected @key ../system.atributoDano}}>{{short}}</option>{{/each}}
        </select>
      </label>
      <label>Daño base<input type="number" name="system.danoBase" value="{{system.danoBase}}"></label>
      <label>Iniciativa<input type="number" name="system.iniciativa" value="{{system.iniciativa}}"></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Equipada</label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "armadura")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields proteccion-fields">
      <label>Protección al daño<input type="number" name="system.nivel" value="{{system.nivel}}"></label>
      <label>Penalizador SRD<input type="number" value="{{protectionPenalty}}" disabled></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Equipada</label>
      <label>Automatismo
        <select name="system.automatismo">
          {{#each automationOptions}}<option value="{{value}}" {{imsSelected value ../system.automatismo}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "escudo")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields proteccion-fields">
      <label>Bonificador a Agilidad<input type="number" name="system.nivel" value="{{system.nivel}}"></label>
      <label>Penalizador SRD<input type="number" value="{{protectionPenalty}}" disabled></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Equipado</label>
      <label>Automatismo
        <select name="system.automatismo">
          {{#each automationOptions}}<option value="{{value}}" {{imsSelected value ../system.automatismo}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "poder")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields poder-fields">
      <label>Tipo<input name="system.tipo" value="{{system.tipo}}"></label>
      <label>Habilidad
        <select name="system.habilidad">
          {{#each config.habilidades}}<option value="{{@key}}" {{imsSelected @key ../system.habilidad}}>{{label}}</option>{{/each}}
        </select>
      </label>
      <label>Atributo de referencia
        <select name="system.atributo">
          {{#each config.atributos}}<option value="{{@key}}" {{imsSelected @key ../system.atributo}}>{{short}}</option>{{/each}}
        </select>
      </label>
      <label>Dificultad<input type="number" name="system.dificultad" value="{{system.dificultad}}"></label>
      <label>Preparación<input name="system.preparacion" value="{{system.preparacion}}"></label>
      <label>Lanzamiento<input name="system.lanzamiento" value="{{system.lanzamiento}}"></label>
      <label>Duración<input name="system.duracion" value="{{system.duracion}}"></label>
      <label>Caducidad<input name="system.caducidad" value="{{system.caducidad}}"></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Disponible</label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "talento")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields talento-fields">
      <label>Usos<input type="number" name="system.usos.valor" value="{{system.usos.valor}}"></label>
      <label>Usos max<input type="number" name="system.usos.max" value="{{system.usos.max}}"></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Equipado</label>
      <label>Habilidad de uso
        <select name="system.habilidadUso">
          <option value="">Sin tirada</option>
          {{#each config.habilidades}}<option value="{{@key}}" {{imsSelected @key ../system.habilidadUso}}>{{label}}</option>{{/each}}
        </select>
      </label>
      <label>Dificultad de uso<input type="number" name="system.dificultadUso" value="{{system.dificultadUso}}"></label>
      <label>Automatismo
        <select name="system.automatismo">
          {{#each automationOptions}}<option value="{{value}}" {{imsSelected value ../system.automatismo}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "equipo")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields equipo-fields">
      <label>Cantidad<input type="number" name="system.cantidad" value="{{system.cantidad}}"></label>
      <label>Uso<input name="system.uso" value="{{system.uso}}"></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Equipado</label>
      <label>Habilidad de uso
        <select name="system.habilidadUso">
          <option value="">Sin tirada</option>
          {{#each config.habilidades}}<option value="{{@key}}" {{imsSelected @key ../system.habilidadUso}}>{{label}}</option>{{/each}}
        </select>
      </label>
      <label>Dificultad de uso<input type="number" name="system.dificultadUso" value="{{system.dificultadUso}}"></label>
      <label>Automatismo
        <select name="system.automatismo">
          {{#each automationOptions}}<option value="{{value}}" {{imsSelected value ../system.automatismo}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "objeto")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields equipo-fields">
      <label>Cantidad<input type="number" name="system.cantidad" value="{{system.cantidad}}"></label>
      <label>Uso<input name="system.uso" value="{{system.uso}}"></label>
      <label class="check"><input type="checkbox" name="system.equipado" {{imsChecked system.equipado}}> Equipado</label>
      <label>Habilidad de uso
        <select name="system.habilidadUso">
          <option value="">Sin tirada</option>
          {{#each config.habilidades}}<option value="{{@key}}" {{imsSelected @key ../system.habilidadUso}}>{{label}}</option>{{/each}}
        </select>
      </label>
      <label>Dificultad de uso<input type="number" name="system.dificultadUso" value="{{system.dificultadUso}}"></label>
      <label>Automatismo
        <select name="system.automatismo">
          {{#each automationOptions}}<option value="{{value}}" {{imsSelected value ../system.automatismo}}>{{label}}</option>{{/each}}
        </select>
      </label>
    </div>
  </section>
  {{/if}}

  {{#if (eq item.type "arquetipo")}}
  <section class="ims-item-panel">
    <div class="ims-item-fields arquetipo-fields">
      <label>Clave de arquetipo<input name="system.arquetipoKey" value="{{system.arquetipoKey}}"></label>
      <label>Género<input name="system.genero" value="{{system.genero}}"></label>
      <label>Perfil<input name="system.perfil" value="{{system.perfil}}"></label>
      <label>{{imsTerm "proezas"}}<input type="number" name="system.proezas" value="{{system.proezas}}"></label>
      <label>{{imsTerm "salud"}} base<input type="number" name="system.saludBase" value="{{system.saludBase}}"></label>
      <label>Resistencia fisica<input type="number" name="system.resistenciaFisica" value="{{system.resistenciaFisica}}"></label>
      <label>{{imsTerm "talento"}}<input name="system.talentoNombre" value="{{system.talentoNombre}}"></label>
    </div>
  </section>
  {{/if}}

  <label class="ims-description ims-item-description">Descripción<textarea name="system.descripcion">{{descripcionTexto}}</textarea></label>
</form>
